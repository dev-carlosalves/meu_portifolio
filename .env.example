# Variáveis de ambiente — Portfólio de Carlos Daniel
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o arquivo .env no repositório.

# ── EmailJS (Sprint 7) ─────────────────────────────────────────
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key

# ── Servidor (desenvolvimento) ─────────────────────────────────
HOST=127.0.0.1
PORT=8000
DEBUG=true

# ── SEO / Deploy (produção) ────────────────────────────────────
BASE_URL=https://carlosdaniel.dev
